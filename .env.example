# Copy to `.env` in this folder (gitignored). Restart Metro after changes.

# Remote processing-pipeline API
EXPO_PUBLIC_AI_SCRIBE_API_URL=http://your-api-host:8100
# API key for the backend auth middleware
EXPO_PUBLIC_AI_SCRIBE_API_KEY=

# Eclipse (InsightOut) API
EXPO_PUBLIC_ECLIPSE_API_URL=https://prod.api.insightout.ttgda.com
EXPO_PUBLIC_ECLIPSE_APPOINTMENTS_QUERY_UUID=
EXPO_PUBLIC_ECLIPSE_API_TOKEN=

# Microsoft Entra ID — Talisman Solutions
EXPO_PUBLIC_AZURE_CLIENT_ID=
EXPO_PUBLIC_AZURE_TENANT_ID=

# Microsoft Entra ID — Excelsiainjurycare
EXPO_PUBLIC_EXCELSIAINJURY_CLIENT_ID=
EXPO_PUBLIC_EXCELSIAINJURY_TENANT_ID=

# App Review demo credentials (used by "App Review / Demo Access")
EXPO_PUBLIC_APP_REVIEW_USERNAME=
EXPO_PUBLIC_APP_REVIEW_PASSWORD=
